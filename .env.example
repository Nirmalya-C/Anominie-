# .env.example
# Copy this file to .env and fill in your Firebase project credentials.
# Never commit your real .env file to version control.
#
# To find these values:
#   1. Go to https://console.firebase.google.com/
#   2. Open your project → Project settings → General → Your apps → Web app
#   3. Copy each value from the firebaseConfig object shown there.

# Firebase Web API Key
FIREBASE_API_KEY=your-api-key-here

# Firebase Auth domain (e.g. your-project.firebaseapp.com)
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Firestore / project ID
FIREBASE_PROJECT_ID=your-project-id

# Firebase Storage bucket (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Cloud Messaging sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ─── Backend / Firebase Admin SDK ──────────────────────────────────────────────
# Required only for the Express backend (backend/server.js).
# Store the entire service account JSON as a single-line string.
# Generate a new private key in Firebase console → Project settings →
# Service accounts → Generate new private key, then minify the JSON and
# paste it here (or store it as a Vercel secret).
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id",...}
